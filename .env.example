# ─────────────────────────────────────────────────────────────────────
#  Gelegram – Environment Configuration Template
#  Copy this file to .env and fill in the values.
#  NEVER commit the actual .env file to version control!
# ─────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────
# Your Telegram Bot Token from @BotFather
# Message @BotFather on Telegram, send /newbot, and paste the token here.
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz

# ── Optional ──────────────────────────────────────────────────────────

# Full path to the gemini executable.
# Default: "gemini"  (assumes it is on your system PATH)
# Windows (npm install): usually at %APPDATA%\npm\gemini.cmd
# Run: where gemini    in PowerShell to find the exact path.
GEMINI_CLI_PATH=gemini

# Working directory for the gemini-cli subprocess.
# Gemini will read and write files here.
# The agentic workspace (GEMINI.md, memory/, skills/, etc.) is scaffolded here
# on first run. Use an absolute path for reliability.
# Example: D:\my-agent-workspace
GEMINI_WORKING_DIR=.\workdir

# Maximum seconds to wait for a Gemini response before sending the user
# a "still working" notification. After this, the bot waits up to 30 minutes.
# Default: 120
ACP_TIMEOUT=120

# Optional bot password. If set, users must send this password before the bot
# will accept any messages from them. Authenticated chat IDs are saved in
# trusted_users.json so users don't re-authenticate after restarts.
# Leave empty (or remove this line) to allow all users without authentication.
BOT_PASSWORD=
