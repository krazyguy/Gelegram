# Git ignore file for Gelegram project
# Secrets and runtime files that should never be committed

# ── Environment secrets ────────────────────────────────────────────────
.env
# .env.example IS committed intentionally — it's the configuration template

# ── Python build artifacts ─────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── Virtual environment ────────────────────────────────────────────────
.venv/
venv/
env/

# ── Runtime logs ──────────────────────────────────────────────────────
*.log

# ── Runtime state files ───────────────────────────────────────────────
bot.pid
trusted_users.json

# ── Service / Gateway artifacts ───────────────────────────────────────
tools/
logs/
# Written by install_service.ps1 — contains the real USERPROFILE path for the
# MSA (Microsoft account) env fix; machine-specific, must not be committed.
service_userprofile.txt

# ── Default agentic workspace ──────────────────────────────────────────
workdir/

# ── IDE files ──────────────────────────────────────────────────────────
.vscode/
.idea/
